{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ghostwire://schemas/team_assembly",
  "title": "TeamAssembly",
  "description": "AI Team Assembler output. Each member carries feedback_signal_ref so AC-3 (behavioral data must be used) is structural: a member selected with no reference to a FeedbackIntelligence signal is invalid. rationale per member feeds the Explainability Engine.",
  "type": "object",
  "additionalProperties": false,
  "required": ["team", "gaps", "risks", "alternatives", "rationale"],
  "properties": {
    "team": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["employee_id", "role", "match_score", "feedback_signal_ref", "rationale"],
        "properties": {
          "employee_id": { "type": "string" },
          "role": { "type": "string" },
          "match_score": { "type": "number", "description": "[0,1]." },
          "feedback_signal_ref": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source", "signal"],
            "description": "The behavioral/feedback signal that influenced selection. source is the FeedbackIntelligence record id; signal is the human-readable factor.",
            "properties": {
              "source": { "type": "string" },
              "signal": { "type": "string" }
            }
          },
          "rationale": { "type": "string" }
        }
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["skill", "severity"],
        "properties": {
          "skill": { "type": "string" },
          "severity": { "type": "string", "enum": ["low", "medium", "high"] }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["text", "severity"],
        "properties": {
          "text": { "type": "string" },
          "severity": { "type": "string", "enum": ["low", "medium", "high"] }
        }
      }
    },
    "alternatives": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["employee_id", "role", "match_score"],
        "properties": {
          "employee_id": { "type": "string" },
          "role": { "type": "string" },
          "match_score": { "type": "number" }
        }
      }
    },
    "rationale": { "type": "string", "description": "Overall team-composition reasoning (Explainability)." }
  }
}
