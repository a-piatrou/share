# GHOSTWIRE backend env template. Copy to backend/.env (gitignored) and adjust.
# NEVER commit a real .env. Phase-1 core does NOT require any Claude credential.

# --- Datastores (match docker-compose.yml host port mappings) ---
DATABASE_URL=postgresql+asyncpg://ghostwire:ghostwire@localhost:5432/ghostwire
WEAVIATE_HOST=localhost
WEAVIATE_HTTP_PORT=8080
WEAVIATE_GRPC_PORT=50051
T2V_URL=http://localhost:9090

# --- Claude credentials (read but unused by Phase-1 core; wired for Phase-2 feature modules) ---
# Prefer a Console key if set; else the subscription OAuth token; else a labelled stub client.
# ANTHROPIC_API_KEY=sk-ant-api...
# ANTHROPIC_AUTH_TOKEN=sk-ant-oat01...

# --- Observability (optional) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
SERVICE_NAME=ghostwire-backend
APP_VERSION=0.1.0
